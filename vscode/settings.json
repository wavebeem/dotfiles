  "editor.tokenColorCustomizations": {
    "[Gruvbox Dark Medium]": {
      "textMateRules": [
        {
          "scope": [
            "variable.other",
            "variable.other.readwrite",
            "variable.other.constant",
            "variable.name",
            "meta.parameter.type.variable",
            "string.constant.other.placeholder",
            "entity.name.function",
          ],
          "settings": { "foreground": "#ebdbb2" },
        },
        {
          "scope": [
            "meta.definition.variable variable.other.readwrite",
            "meta.definition.variable variable.other.constant",
            "variable.parameter",
          ],
          "settings": { "foreground": "#83a598" },
        },
        {
          "scope": [
            "meta.definition.function entity.name.function",
            "meta.definition.method entity.name.function",
            "meta.definition.variable entity.name.function",
          ],
          "settings": { "foreground": "#d3869b" },
        },
        {
          "scope": ["meta.brace", "brace"],
          "settings": { "foreground": "#a89984" },
        },
      ],
    },
    "[Gruvbox Dark Hard]": {
      "textMateRules": [
        {
          "scope": [
            "variable.other",
            "variable.other.readwrite",
            "variable.other.constant",
            "variable.name",
            "meta.parameter.type.variable",
            "string.constant.other.placeholder",
            "entity.name.function",
          ],
          "settings": { "foreground": "#ebdbb2" },
        },
        {
          "scope": [
            "meta.definition.variable variable.other.readwrite",
            "meta.definition.variable variable.other.constant",
            "variable.parameter",
          ],
          "settings": { "foreground": "#83a598" },
        },
        {
          "scope": [
            "meta.definition.function entity.name.function",
            "meta.definition.method entity.name.function",
            "meta.definition.variable entity.name.function",
          ],
          "settings": { "foreground": "#d3869b" },
        },
        {
          "scope": ["meta.brace", "brace"],
          "settings": { "foreground": "#a89984" },
        },
      ],
    },
    "[Gruvbox Dark Soft]": {
      "textMateRules": [
        {
          "scope": [
            "variable.other",
            "variable.other.readwrite",
            "variable.other.constant",
            "variable.name",
            "meta.parameter.type.variable",
            "string.constant.other.placeholder",
            "entity.name.function",
          ],
          "settings": { "foreground": "#ebdbb2" },
        },
        {
          "scope": [
            "meta.definition.variable variable.other.readwrite",
            "meta.definition.variable variable.other.constant",
            "variable.parameter",
          ],
          "settings": { "foreground": "#83a598" },
        },
        {
          "scope": [
            "meta.definition.function entity.name.function",
            "meta.definition.method entity.name.function",
            "meta.definition.variable entity.name.function",
          ],
          "settings": { "foreground": "#d3869b" },
        },
        {
          "scope": ["meta.brace", "brace"],
          "settings": { "foreground": "#a89984" },
        },
      ],
    },
  },
